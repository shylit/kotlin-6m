package com.example.nobelapp.data.remote

import io.ktor.client.HttpClient
import io.ktor.client.call.body
import io.ktor.client.request.get
import io.ktor.client.request.parameter

class NobelApiService(
    private val client: HttpClient
) {
    suspend fun getPrizes(year: String?, category: String?): NobelResponseDto {
        return client.get("https://api.nobelprize.org/2.1/nobelPrizes") {
            parameter("limit", 25)
            parameter("offset", 0)

            if (!year.isNullOrBlank()) {
                parameter("nobelPrizeYear", year)
            }

            if (!category.isNullOrBlank() && category != "All") {
                parameter("nobelPrizeCategory", category)
            }
        }.body()
    }
}
