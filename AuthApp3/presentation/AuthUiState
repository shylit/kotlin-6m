package com.example.authapp.presentation

import com.example.authapp.domain.model.AppUser

sealed class AuthUiState {
    object Login : AuthUiState()
    object Loading : AuthUiState()
    data class UsersSuccess(val users: List<AppUser>) : AuthUiState()
    data class DetailSuccess(val user: AppUser) : AuthUiState()
    data class Error(val message: String) : AuthUiState()
}
